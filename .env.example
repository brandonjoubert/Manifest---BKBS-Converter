# Optional env fallbacks (UI Settings take priority when saved in the app)

# Preferred generic names
LLM_API_KEY=
LLM_BASE_URL=https://api.x.ai/v1
LLM_PROVIDER=xai
BKBS_MODEL=grok-4.5

# Or provider-specific aliases
XAI_API_KEY=
OPENAI_API_KEY=

# Allow crawling private/local IPs (for testing sites on localhost)
BKBS_ALLOW_PRIVATE_URLS=1

# App
BKBS_HOST=127.0.0.1
BKBS_PORT=8765
BKBS_DATA_DIR=./data

# Default public web root for live publish (shared hosting)
# Example: /home/username/public_html
DEFAULT_PUBLISH_ROOT=
